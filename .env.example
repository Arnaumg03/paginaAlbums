# Stripe Configuration
# Para usar esta aplicación con Stripe, necesitas:
# 1. Crear una cuenta en https://stripe.com
# 2. Obtener tus claves de API desde https://dashboard.stripe.com/apikeys
# 3. Crear productos y precios en Stripe Dashboard

# Clave pública de Stripe (usa la misma versión: test o live)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Clave secreta de Stripe (usa la misma versión que la pública: test o live)
STRIPE_SECRET_KEY=sk_test_...

# Price IDs creados en Stripe Dashboard
# Para crear: Stripe Dashboard → Products → Create product → Add pricing
# Ejemplo de price ID: price_1A2B3C4D5E6F7G8H
PRICE_ID_PHYSICAL=price_...
PRICE_ID_DIGITAL=price_...

# Webhook Secret (opcional, solo si usas webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

